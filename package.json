{
  "name": "shattered-worlds",
  "description": "Shattered Worlds System @HwanDr",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Nikita Temerko",
  "version": "0.12.14",
  "contributors": [
    "Nikita Temerko"
  ],
  "imports": {},
  "dependencies": {
    "@fontsource-variable/tektur": "^5.2.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "cssnano": "^7.1.9",
    "vite": "^7.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@league-of-foundry-developers/foundry-vtt-types": "^13.345.1",
    "@tsconfig/svelte": "^4.0.1",
    "autoprefixer": "^10.5.0",
    "postcss-preset-env": "^10.6.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "terser": "^5.48.0",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    ">5%",
    "not IE 11"
  ],
  "scripts": {
    "analyze": "ANALYZE=1 vite build --mode production",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "dev": "vite",
    "lint": "biome check",
    "tsc:check": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "watch": "vite build --watch --mode development",
    "pack": "npm run build && zip -r shattered-worlds.zip dist/ data/ lang/ templates/ template.json system.json",
    "bump:patch": "npm version patch --no-git-tag-version && node scripts/update-system-version.js && node scripts/update-readme.js",
    "bump:minor": "npm version minor --no-git-tag-version && node scripts/update-system-version.js && node scripts/update-readme.js",
    "bump:major": "npm version major --no-git-tag-version && node scripts/update-system-version.js && node scripts/update-readme.js"
  }
}
